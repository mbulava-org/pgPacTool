<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>

    <!-- Package Metadata -->
    <PackageId>MSBuild.Sdk.PostgreSql</PackageId>
    <Title>MSBuild SDK for PostgreSQL Database Projects</Title>
    <Description>MSBuild SDK that enables SQL Server-style database project workflow for PostgreSQL. Build .csproj files with SQL scripts into deployable .pgpac packages.</Description>
    <Authors>mbulava</Authors>
    <Company>mbulava</Company>
    <Copyright>© 2026 Mike Bulava. All rights reserved.</Copyright>
    <PackageTags>postgresql;database;msbuild;sdk;dacpac;pgpac;sql;devops</PackageTags>
    <PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageProjectUrl>https://github.com/mbulava-org/pgPacTool</PackageProjectUrl>
    <RepositoryUrl>https://github.com/mbulava-org/pgPacTool</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!-- SDK Package Configuration -->
    <IsPackable>true</IsPackable>
    <IncludeBuildOutput>true</IncludeBuildOutput>
    <DevelopmentDependency>true</DevelopmentDependency>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <GenerateDependencyFile>true</GenerateDependencyFile>
    <GenerateRuntimeConfigurationFiles>true</GenerateRuntimeConfigurationFiles>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);CopyTaskRuntimeDependenciesToPackage</TargetsForTfmSpecificBuildOutput>
    <BuildOutputTargetFolder>tasks</BuildOutputTargetFolder>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <NoWarn>$(NoWarn);NU5100;NU5118</NoWarn>

    <!-- Version -->
    <Version>1.0.0-preview5</Version>
  </PropertyGroup>

  <!-- Include SDK files in package -->
  <ItemGroup>
    <None Include="Sdk\**\*" Pack="true" PackagePath="Sdk\" />
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="LICENSE.txt" Pack="true" PackagePath="\" />
  </ItemGroup>

  <!-- Dependencies for build tasks -->
  <ItemGroup>
    <PackageReference Include="Microsoft.Build.Framework" Version="18.3.3" PrivateAssets="all" ExcludeAssets="Runtime" />
    <PackageReference Include="Microsoft.Build.Utilities.Core" Version="18.3.3" PrivateAssets="all" ExcludeAssets="Runtime" />
  </ItemGroup>

  <!-- Reference to our DAC library -->
  <ItemGroup>
    <ProjectReference Include="..\..\libs\mbulava.PostgreSql.Dac\mbulava.PostgreSql.Dac.csproj" />
    <ProjectReference Include="..\..\postgresPacTools\postgresPacTools.csproj" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- Include task runtime dependencies in the SDK package -->
  <Target Name="CopyTaskRuntimeDependenciesToPackage" DependsOnTargets="ResolveReferences">
    <PropertyGroup>
      <_CliOutputDirectory>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\..\..\postgresPacTools\bin\$(Configuration)\$(TargetFramework)\'))</_CliOutputDirectory>
    </PropertyGroup>

    <ItemGroup>
      <_TaskAssemblies Include="$(OutputPath)*.dll" Exclude="$(OutputPath)ref\**\*;$(OutputPath)refint\**\*" />
      <_TaskRuntimeFiles Include="$(OutputPath)runtimes\**\*.*" />
      <_CliHostFiles Include="$(_CliOutputDirectory)**\*.*"
                     Exclude="$(_CliOutputDirectory)ref\**\*;$(_CliOutputDirectory)refint\**\*;$(_CliOutputDirectory)**\*.pdb" />

      <BuildOutputInPackage Include="@(_TaskAssemblies)" TargetPath="%(Filename)%(Extension)" />
      <BuildOutputInPackage Include="@(_TaskRuntimeFiles)" TargetPath="runtimes\%(RecursiveDir)%(Filename)%(Extension)" />
      <BuildOutputInPackage Include="@(_CliHostFiles)" TargetPath="cli\%(RecursiveDir)%(Filename)%(Extension)" />
    </ItemGroup>
  </Target>

  <Target Name="AddTaskDependencyFilesToBuiltProjectOutputGroupOutput" BeforeTargets="BuiltProjectOutputGroup">
    <ItemGroup>
      <BuiltProjectOutputGroupOutput Include="$(ProjectDepsFilePath)" TargetPath="$(ProjectDepsFileName)" FinalOutputPath="$(ProjectDepsFilePath)" Condition="Exists('$(ProjectDepsFilePath)')" />
      <BuiltProjectOutputGroupOutput Include="$(OutputPath)$(AssemblyName).runtimeconfig.json" TargetPath="$(AssemblyName).runtimeconfig.json" FinalOutputPath="$(OutputPath)$(AssemblyName).runtimeconfig.json" Condition="Exists('$(OutputPath)$(AssemblyName).runtimeconfig.json')" />
    </ItemGroup>
  </Target>

</Project>
