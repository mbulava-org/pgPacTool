<Project>
	<!-- This file is automatically included by projects that reference Npgquery -->
	<!-- It ensures native libraries are copied to the output directory -->

	<ItemGroup>
		<!-- Define native library locations based on runtime -->
		<NativeLibraryWin Include="$(MSBuildThisFileDirectory)..\runtimes\win-x64\native\pg_query.dll" Condition="'$(OS)' == 'Windows_NT'" />
		<NativeLibraryLinux Include="$(MSBuildThisFileDirectory)..\runtimes\linux-x64\native\pg_query.so" Condition="'$(OS)' != 'Windows_NT'" />
	</ItemGroup>

	<!-- Copy native libraries to output directory after build -->
	<Target Name="CopyNpgqueryNativeLibraries" AfterTargets="Build">
		<!-- Copy to root output for direct loading -->
		<Copy 
			SourceFiles="@(NativeLibraryWin)" 
			DestinationFolder="$(OutputPath)" 
			SkipUnchangedFiles="true" 
			Condition="'$(OS)' == 'Windows_NT' AND '@(NativeLibraryWin)' != ''" />
		<Copy 
			SourceFiles="@(NativeLibraryLinux)" 
			DestinationFolder="$(OutputPath)" 
			SkipUnchangedFiles="true" 
			Condition="'$(OS)' != 'Windows_NT' AND '@(NativeLibraryLinux)' != ''" />

		<!-- Also copy to runtime-specific folder for .NET runtime probing -->
		<Copy 
			SourceFiles="@(NativeLibraryWin)" 
			DestinationFolder="$(OutputPath)runtimes\win-x64\native\" 
			SkipUnchangedFiles="true" 
			Condition="'$(OS)' == 'Windows_NT' AND '@(NativeLibraryWin)' != ''" />
		<Copy 
			SourceFiles="@(NativeLibraryLinux)" 
			DestinationFolder="$(OutputPath)runtimes\linux-x64\native\" 
			SkipUnchangedFiles="true" 
			Condition="'$(OS)' != 'Windows_NT' AND '@(NativeLibraryLinux)' != ''" />
	</Target>
</Project>
